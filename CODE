import tkinter as tk
from tkinter import messagebox


# Function to convert temperature
def convert_temperature():
    try:
        fahrenheit = float(entry.get())

        celsius = (fahrenheit - 32) * 5 / 9

        result_label.config(
            text=f"{fahrenheit}°F = {celsius:.2f}°C",
            fg="green"
        )

    except ValueError:
        messagebox.showerror(
            "Invalid Input",
            "Please enter a valid temperature!"
        )


# Function to clear input
def clear():
    entry.delete(0, tk.END)
    result_label.config(text="")


# Create main window
window = tk.Tk()
window.title("🌡 Temperature Converter")
window.geometry("400x350")
window.config(bg="#E3F2FD")


# Heading
title = tk.Label(
    window,
    text=" Fahrenheit to Celsius Converter ",
    font=("Arial", 16, "bold"),
    bg="#E3F2FD"
)

title.pack(pady=20)


# Input label
label = tk.Label(
    window,
    text="Enter Temperature in Fahrenheit:",
    font=("Arial", 12),
    bg="#E3F2FD"
)

label.pack()


# Input box
entry = tk.Entry(
    window,
    font=("Arial", 14),
    justify="center"
)

entry.pack(pady=10)


# Convert button
convert_button = tk.Button(
    window,
    text="Convert 🌡",
    font=("Arial", 12, "bold"),
    bg="#2196F3",
    fg="white",
    command=convert_temperature
)

convert_button.pack(pady=10)


# Result display
result_label = tk.Label(
    window,
    text="",
    font=("Arial", 14, "bold"),
    bg="#E3F2FD"
)

result_label.pack(pady=15)


# Clear button
clear_button = tk.Button(
    window,
    text="Clear",
    font=("Arial", 12),
    bg="#FF7043",
    fg="white",
    command=clear
)

clear_button.pack()


# Footer
footer = tk.Label(
    window,
    text="Made with Python ",
    font=("Arial", 10),
    bg="#E3F2FD"
)

footer.pack(side="bottom", pady=10)


# Run application
window.mainloop()
